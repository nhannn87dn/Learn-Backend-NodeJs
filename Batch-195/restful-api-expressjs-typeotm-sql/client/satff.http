@baseUrl = http://localhost:8080

### create new staff
POST {{baseUrl}}/api/v1/staffs
Content-Type: application/json

{
    "fullName": "John Doe",
    "email": "john.doe@example.com",
    "password": "password123",
    "role": "staff"
}

